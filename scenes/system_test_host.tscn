[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/system_test_host.gd" id="1"]

[node name="SystemTestHost" type="Node"]
script = ExtResource("1")

[node name="ContentRoot" type="Node" parent="."]

[node name="Overlay" type="CanvasLayer" parent="."]

[node name="MarginContainer" type="MarginContainer" parent="Overlay"]
anchors_preset = 10
anchor_right = 1.0
offset_left = 16.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = 164.0
grow_horizontal = 2

[node name="PanelContainer" type="PanelContainer" parent="Overlay/MarginContainer"]
layout_mode = 2

[node name="MarginContainer" type="MarginContainer" parent="Overlay/MarginContainer/PanelContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/margin_left = 14
theme_override_constants/margin_top = 14
theme_override_constants/margin_right = 14
theme_override_constants/margin_bottom = 14

[node name="VBoxContainer" type="VBoxContainer" parent="Overlay/MarginContainer/PanelContainer/MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="TitleLabel" type="Label" parent="Overlay/MarginContainer/PanelContainer/MarginContainer/VBoxContainer"]
layout_mode = 2
text = "Suite Title"

[node name="SummaryLabel" type="Label" parent="Overlay/MarginContainer/PanelContainer/MarginContainer/VBoxContainer"]
layout_mode = 2
text = "Suite summary"
autowrap_mode = 3

[node name="ButtonsRow" type="HBoxContainer" parent="Overlay/MarginContainer/PanelContainer/MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="BackButton" type="Button" parent="Overlay/MarginContainer/PanelContainer/MarginContainer/VBoxContainer/ButtonsRow"]
layout_mode = 2
text = "Back To Picker"

[node name="ReloadButton" type="Button" parent="Overlay/MarginContainer/PanelContainer/MarginContainer/VBoxContainer/ButtonsRow"]
layout_mode = 2
text = "Reload Suite"

[connection signal="pressed" from="Overlay/MarginContainer/PanelContainer/MarginContainer/VBoxContainer/ButtonsRow/BackButton" to="." method="_on_back_button_pressed"]
[connection signal="pressed" from="Overlay/MarginContainer/PanelContainer/MarginContainer/VBoxContainer/ButtonsRow/ReloadButton" to="." method="_on_reload_button_pressed"]
