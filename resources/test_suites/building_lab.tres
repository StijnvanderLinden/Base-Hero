[resource]
script = ExtResource("1")
suite_id = "building_lab"
title = "Building Lab"
summary = "Run an isolated build sandbox with free wall and turret placement, repair loops, and a manual enemy spawn for turret validation. This avoids entering a full gate or raid just to test building changes."
